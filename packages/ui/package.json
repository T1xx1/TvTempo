{
	"name": "@tvtempo/ui",
	"version": "0.1.0",
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"scripts": {
		"dev": "svelte-package -w",
