		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"publint": "^0.3.21",
		"shadcn-svelte": "^1.4.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
