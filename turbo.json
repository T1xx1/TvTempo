{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"concurrency": "100%",
	"tasks": {
		"dev": {
			"persistent": true,
			"cache": false
		},
		"build": {
			"outputs": ["dist/**"]
		},
		"@tvtempo/webapp#dev": {
			"persistent": true,
			"cache": false
		},
		"@tvtempo/webapp#build": {
			"dependsOn": ["^build"],
			"env": [
				"ENABLE_EXPERIMENTAL_COREPACK",
				"PUBLIC_AUTH_REDIRECT_URL",
				"TRAKT_CLIENT_ID",
				"TRAKT_CLIENT_SECRET"
			],
			"outputs": [".vercel/**"]
		}
	}
}
